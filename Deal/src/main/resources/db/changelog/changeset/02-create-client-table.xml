<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://liquibase.org"
        xmlns:xsi="http://w3.org"
        xsi:schemaLocation="http://liquibase.org
        http://liquibase.org/dbchangelog-latest.xsd">

    <changeSet id="20260401-002" author="Alvarans">
        <createTable tableName="client">
            <column name="client_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="middle_name" type="VARCHAR(255)"/>
            <column name="birth_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="gender" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="marital_status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="dependent_amount" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="passport_id" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="employment_id" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="account_number" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>